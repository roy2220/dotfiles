#!/usr/bin/env bash

set -o errexit -o nounset -o pipefail # -o xtrace

DOWNLOAD_URL=$(curl --silent --show-error --fail --request GET --location https://api.github.com/repos/simeji/jid/releases/latest | python2 -c "\
import json
import sys

releases = json.loads(sys.stdin.read())
download_url = None
for asset in releases['assets']:
    if asset['name'] == 'jid_linux_amd64.zip':
        download_url = asset['browser_download_url']
        break
if download_url is None:
    print >> sys.stderr, 'download url not found'
    sys.exit(1)
print download_url
")
TEMP_FILE=$(mktemp)
curl --silent --show-error --fail --request GET --location "${DOWNLOAD_URL}" --output "${TEMP_FILE}"
TEMP_DIR=$(mktemp --directory)
unzip -d "${TEMP_DIR}" "${TEMP_FILE}"
rm --force "${TEMP_FILE}"
DIR=$(dirname $(realpath "$0"))
install -D "${TEMP_DIR}/jid" "${DIR}/jid"
rm --force --recursive "${TEMP_DIR}"
